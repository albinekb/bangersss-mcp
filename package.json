{
  "name": "bangersss",
  "version": "0.3.4",
  "private": true,
  "description": "Music organization tools for DJs - MCP server, CLI, and core library",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albinekb/bangersss-mcp.git"
  },
  "homepage": "https://github.com/albinekb/bangersss-mcp#readme",
  "bugs": {
    "url": "https://github.com/albinekb/bangersss-mcp/issues"
  },
  "keywords": [
    "mcp",
    "music",
    "dj",
    "rekordbox",
    "engine-dj",
    "bpm",
    "id3",
    "playlist",
    "model-context-protocol"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:mcp": "pnpm --filter @bangersss/mcp run dev",
    "dev:cli": "pnpm --filter @bangersss/cli run dev"
  },
  "devDependencies": {
    "@types/bytes": "^3.1.5",
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3-multiple-ciphers",
      "esbuild"
    ]
  }
}
