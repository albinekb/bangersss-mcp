{
  "name": "bangersss-mcp",
  "version": "0.3.0",
  "description": "MCP server for organizing music with LLM assistance - built for DJs",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bangersss-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albinekb/bangersss-mcp.git"
  },
  "homepage": "https://github.com/albinekb/bangersss-mcp#readme",
  "bugs": {
    "url": "https://github.com/albinekb/bangersss-mcp/issues"
  },
  "keywords": [
    "mcp",
    "music",
    "dj",
    "rekordbox",
    "engine-dj",
    "bpm",
    "id3",
    "playlist",
    "model-context-protocol"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3-multiple-ciphers": "^12.6.2",
    "fast-glob": "^3.3.3",
    "memfs": "^4.17.0",
    "music-metadata": "^10.7.1",
    "nanoid": "^5.1.2",
    "node-id3": "^0.2.6",
    "rekordbox-connect": "^1.2.3",
    "unionfs": "^4.5.4",
    "zod": "^3.25.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
